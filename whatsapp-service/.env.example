PORT=3000

# Token compartido entre este servicio y Django para autenticar llamadas internas.
# Debe coincidir con la variable WHATSAPP_SHARED_TOKEN en el backend de Django.
SHARED_TOKEN=cambia-este-token-secreto

# URL del endpoint de Django que recibe eventos de sesión y entrega de mensajes.
# En Docker Compose, 'backend' es el nombre del servicio Django.
DJANGO_WEBHOOK_URL=http://backend:8000/api/webhooks/whatsapp/
